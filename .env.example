# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL="postgresql://hellenic:hellenic_dev@localhost:5432/hellenic_directory"
REDIS_URL="redis://localhost:6379"

# ── Auth ──────────────────────────────────────────────────────────────────────
JWT_ACCESS_SECRET="change-me-access-secret-min-32-chars"
JWT_REFRESH_SECRET="change-me-refresh-secret-min-32-chars"
JWT_ACCESS_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="30d"

# ── App ───────────────────────────────────────────────────────────────────────
NODE_ENV="development"
PORT=4000
CORS_ORIGINS="http://localhost:3000"
# Base URL of the web client — used to build links in transactional emails.
APP_URL="http://localhost:3000"
APP_OWNER_EMAIL="admin@hellenicdir.com"
# Required for seeding — no default to prevent known-password production accounts.
SEED_OWNER_PASSWORD=""

# ── Email (Resend) ─────────────────────────────────────────────────────────────
RESEND_API_KEY="re_..."
EMAIL_FROM="noreply@hellenicdir.com"

# ── File Storage (Supabase Storage or S3) ─────────────────────────────────────
STORAGE_PROVIDER="supabase"          # "supabase" | "s3"
SUPABASE_URL="https://your-project.supabase.co"
SUPABASE_SERVICE_ROLE_KEY="eyJ..."
# -- OR for AWS S3 --
AWS_ACCESS_KEY_ID=""
AWS_SECRET_ACCESS_KEY=""
AWS_S3_BUCKET=""
AWS_S3_REGION="us-east-1"

# ── Push Notifications ────────────────────────────────────────────────────────
FIREBASE_PROJECT_ID=""
FIREBASE_CLIENT_EMAIL=""
FIREBASE_PRIVATE_KEY=""

# ── Stripe (Phase 3) ─────────────────────────────────────────────────────────
STRIPE_SECRET_KEY="sk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."

# ── Web app (Next.js) ─────────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL="http://localhost:4000/api/v1"
NEXT_PUBLIC_GOOGLE_MAPS_KEY=""
